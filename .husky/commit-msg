#!/bin/sh
# Commit message validation hook

set -e

ALLOWED_PREFIXES="feat|fix|chore|docs|refactor|revert"

commit_msg_file="$1"
first_line=$(head -1 "$commit_msg_file")

# Check if message is empty
if [ -z "$first_line" ]; then
    echo "Error: commit message is empty"
    exit 1
fi

# 1. Validate first line: prefix: title
if ! echo "$first_line" | grep -qE "^($ALLOWED_PREFIXES): .+"; then
    echo "Error: first line must match 'prefix: title'"
    echo "  Allowed: feat, fix, chore, docs, refactor, revert"
    echo "  Example: feat: add react-optimizer agent"
    exit 1
fi

# 2. Check second line is empty (if exists)
total_lines=$(wc -l < "$commit_msg_file")
if [ "$total_lines" -gt 1 ]; then
    second_line=$(sed -n '2p' "$commit_msg_file")
    if [ -n "$second_line" ]; then
        echo "Error: second line must be empty"
        exit 1
    fi
fi

# 3. Check body lines start with '- ' (if body exists)
if [ "$total_lines" -gt 2 ]; then
    line_num=0
    while IFS= read -r line; do
        line_num=$((line_num + 1))
        if [ "$line_num" -le 2 ]; then continue; fi
        if [ -n "$line" ]; then
            case "$line" in
                "- "*) ;;
                "Co-Authored-By:"*) ;;
                *) echo "Error: body lines must start with '- ' (line $line_num: $line)"; exit 1 ;;
            esac
        fi
    done < "$commit_msg_file"
fi

exit 0
